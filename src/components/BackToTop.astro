---
---

<button
	id="backToTop"
	class="fixed bottom-6 right-6 z-[90] bg-yellow border-3 border-navy rounded-2xl w-14 h-14 flex items-center justify-center shadow-[6px_6px_0_var(--color-navy)] transition-all duration-300 translate-y-24 opacity-0 hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[10px_10px_0_var(--color-navy)] active:translate-x-0 active:translate-y-0 active:shadow-[4px_4px_0_var(--color-navy)] max-md:bottom-4 max-md:right-4 max-md:w-12 max-md:h-12"
	aria-label="Kembali ke atas"
>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="3"
		stroke-linecap="round"
		stroke-linejoin="round"
		class="text-navy"
	>
		<path d="m18 15-6-6-6 6"></path>
	</svg>
</button>

<script>
	const backToTop = document.getElementById("backToTop");

	const toggleVisibility = () => {
		if (window.scrollY > 400) {
			backToTop?.classList.remove("translate-y-24", "opacity-0", "pointer-events-none");
			backToTop?.classList.add("translate-y-0", "opacity-100");
		} else {
			backToTop?.classList.add("translate-y-24", "opacity-0", "pointer-events-none");
			backToTop?.classList.remove("translate-y-0", "opacity-100");
		}
	};

	window.addEventListener("scroll", toggleVisibility);
	
	// Initial check
	toggleVisibility();

	backToTop?.addEventListener("click", () => {
		window.scrollTo({
			top: 0,
			behavior: "smooth",
		});
	});
</script>
